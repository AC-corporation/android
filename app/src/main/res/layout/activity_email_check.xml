<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".EmailCheckActivity">

    <TextView
        android:id="@+id/Title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="30dp"
        android:text="이메일 인증"
        android:textColor="@color/black"
        android:textSize="36dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.29" />

    <TextView
        android:id="@+id/email_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="30dp"
        android:text="학교 이메일을 인증해 주세요"
        android:textSize="12sp"
        android:layout_marginTop="80dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/Title" />

    <EditText
        android:id="@+id/login_stuedntid_et"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="30dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/edittext_round"
        android:hint="이메일"
        android:inputType="textEmailAddress"
        android:paddingStart="20dp"
        android:textColorHint="#B1B8C0"
        android:textSize="13dp"
        app:layout_constraintTop_toBottomOf="@id/email_info"
         />

    <android.widget.Button
        android:id="@+id/send_button"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="30dp"
        android:background="@drawable/login_btn"
        android:paddingLeft="120dp"
        android:paddingRight="130dp"
        android:text="전송하기"
        android:textColor="@color/white"
        android:backgroundTint="#00A7CB"
        android:textSize="14dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@+id/login_stuedntid_et" />


    <TextView
        android:id="@+id/send_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="30dp"
        android:text="으로 인증코드가 전송되었어요"
        android:layout_marginTop="10dp"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/send_button" />


    <EditText
        android:id="@+id/check_num"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        app:layout_constraintTop_toBottomOf="@id/send_info"
        android:layout_marginTop="5dp"
        android:layout_marginHorizontal="30dp"
        android:inputType="textPassword"
        android:hint="인증번호"
        android:paddingStart="20dp"
        android:textColorHint="#B1B8C0"
        android:textSize="13dp"
        android:background="@drawable/edittext_round"
        />

    <android.widget.Button
        android:id="@+id/check_num_button"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="30dp"
        android:background="@drawable/login_btn"
        android:paddingLeft="120dp"
        android:paddingRight="130dp"
        android:text="회원가입"
        android:textColor="#006E93"
        android:textSize="14dp"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@+id/check_num" />

    <android.widget.Button
        android:id="@+id/next_button"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="30dp"
        android:background="@drawable/login_btn"
        android:paddingLeft="120dp"
        android:paddingRight="130dp"
        android:text="회원가입"
        android:textColor="#006E93"
        android:textSize="14dp"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@+id/check_num" />



</androidx.constraintlayout.widget.ConstraintLayout>